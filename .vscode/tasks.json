{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Linux (Debug)",
            "type": "shell",
            "command": "cargo build",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "Build Linux (Release)",
            "type": "shell",
            "command": "cargo build --release",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "Build Windows (Release Cross-Compile)",
            "type": "shell",
            "command": "cargo build --release --target x86_64-pc-windows-gnu",
            "group": "build",
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "Build All Releases (Linux & Windows)",
            "type": "shell",
            "dependsOn": [
                "Build Linux (Release)",
                "Build Windows (Release Cross-Compile)"
            ],
            "group": "build",
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
